{
  "name": "api_tester_skill",
  "description": "执行 API 测试用例，验证响应断言，输出失败的用例 ID",
  "entrypoint": "scripts/run.py",
  "timeout_seconds": 120,
  "input_schema": {
    "type": "object",
    "properties": {
      "base_url": {
        "type": "string",
        "description": "API 基础 URL",
        "default": "http://127.0.0.1:18081"
      },
      "package_id": {
        "type": "string",
        "description": "X-Package-Id 请求头值",
        "default": ""
      },
      "test_cases_path": {
        "type": "string",
        "description": "test_cases.json 文件路径"
      },
      "reset_first": {
        "type": "boolean",
        "description": "是否先调用 reset 接口重置状态",
        "default": true
      }
    },
    "additionalProperties": false
  }
}