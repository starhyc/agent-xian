{
  "name": "date_parser_skill",
  "description": "Parse and normalize various date formats from customer service messages.",
  "entrypoint": "scripts/run.py",
  "timeout_seconds": 30,
  "input_schema": {
    "type": "object",
    "properties": {
      "text": {
        "type": "string",
        "description": "Text content containing dates to parse"
      },
      "format": {
        "type": "string",
        "description": "Target format for output dates",
        "default": "ISO8601"
      },
      "locale": {
        "type": "string",
        "description": "Locale for date parsing",
        "default": "auto"
      }
    },
    "required": ["text"],
    "additionalProperties": false
  }
}