[
  {
    "id": "TC001",
    "description": "获取 token，更新用户 U1003 的邮箱为 u1003.stable@example.com、职级为 Senior Engineer，然后查询 U1003 详情；校验最后一次查询响应。",
    "assert": {
      "expectedStatus": 200,
      "expectedFields": ["code", "data.userId", "data.email", "data.title"],
      "expectedValues": {
        "code": 0,
        "data.userId": "U1003",
        "data.email": "u1003.stable@example.com",
        "data.title": "Senior Engineer"
      }
    }
  },
