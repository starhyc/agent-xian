  {
    "id": "TC006",
    "description": "按 department=platform、page=2、pageSize=2、sortOrder=asc 查询用户列表；校验分页和首条记录。",
    "assert": {
      "expectedStatus": 200,
      "expectedFields": ["code", "data.page", "data.pageSize", "data.total", "data.list.0.userId", "data.list.0.name"],
      "expectedValues": {
        "code": 0,
        "data.page": 2,
        "data.pageSize": 2,
        "data.total": 3,
        "data.list.0.userId": "U1003",
        "data.list.0.name": "Carol"
      }
    }
  },
  {
    "id": "TC007",
    "description": "按 status=active、page=1、pageSize=100、sortOrder=asc 查询用户列表；校验分页、总数和第 100 条记录。",
    "assert": {
      "expectedStatus": 200,
      "expectedFields": ["code", "data.page", "data.pageSize", "data.total", "data.list.0.userId", "data.list.99.userId"],
      "expectedValues": {
        "code": 0,
        "data.page": 1,
        "data.pageSize": 100,
        "data.total": 240,
        "data.list.0.userId": "U2001",
        "data.list.99.userId": "U2100"
      }
    }
  },
